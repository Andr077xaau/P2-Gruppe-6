package com.energiapp.model;

public class EnhedForbrug {

    private int enhedTypeId;
    private int userId;
    private String vaerelse;
    private double watt;
    private double timer;
    private double prisPerKwh;

    public EnhedForbrug() {}

    public EnhedForbrug(int enhedTypeId, int userId, String vaerelse,
                        double watt, double timer, double prisPerKwh) {

        this.enhedTypeId = enhedTypeId;
        this.userId = userId;
        this.vaerelse = vaerelse;
        this.watt = watt;
        this.timer = timer;
        this.prisPerKwh = prisPerKwh;
    }

    // beregner energiforbrug
    public double getForbrugKwh() {
        return (watt * timer) / 1000;
    }

    // beregner pris
    public double getPris() {
        return getForbrugKwh() * prisPerKwh;
    }

    // getters og setters

    public int getEnhedTypeId() {
        return enhedTypeId;
    }

    public void setEnhedTypeId(int enhedTypeId) {
        this.enhedTypeId = enhedTypeId;
    }

    public int getUserId() {
        return userId;
    }

    public void setUserId(int userId) {
        this.userId = userId;
    }

    public String getVaerelse() {
        return vaerelse;
    }

    public void setVaerelse(String vaerelse) {
        this.vaerelse = vaerelse;
    }

    public double getWatt() {
        return watt;
    }

    public void setWatt(double watt) {
        this.watt = watt;
    }

    public double getTimer() {
        return timer;
    }

    public void setTimer(double timer) {
        this.timer = timer;
    }

    public double getPrisPerKwh() {
        return prisPerKwh;
    }

    public void setPrisPerKwh(double prisPerKwh) {
        this.prisPerKwh = prisPerKwh;
    }
}
