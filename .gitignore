# ── Maven ─────────────────────────────────────────────────────────────────────
# Compiled output — rebuilt automatically from source
target/

# ── Vaadin ────────────────────────────────────────────────────────────────────
# Node.js and npm packages downloaded by Vaadin internally (can be 100MB+)
node_modules/
node/
.pnpm-store/

# Files auto-generated by Vaadin on startup — not hand-written code
frontend/generated/
src/main/bundles/
webpack.config.js
vite.config.ts
pnpmfile.cjs
.npmrc

# ── Eclipse IDE ───────────────────────────────────────────────────────────────
# Machine-specific IDE config — breaks other people's setups if committed
.project
.classpath
.settings/

# ── IntelliJ IDEA ─────────────────────────────────────────────────────────────
.idea/
*.iml

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
